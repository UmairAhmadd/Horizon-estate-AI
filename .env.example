# --- PostgreSQL (optional long-term memory) ---------------------------------
# Server-only. LEAVE EMPTY to run fully on localStorage / in-memory mock.
# When set, the app persists listings, leads, conversations, messages, saved
# properties, and lead preferences to Postgres. Credentials never reach the client.
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/horizon_estate?schema=public"
# After setting it:  npm run db:migrate   &&   npm run db:seed
DATABASE_URL=

# --- Saved-properties persistence -------------------------------------------
#   local  (default) Browser localStorage.   api  The /api/saved route.
# With DATABASE_URL set, use "api" so the shortlist persists to Postgres;
# otherwise "api" uses an in-memory mock that resets on restart.
# NEXT_PUBLIC_ var: read in the browser, inlined at build time — rebuild after changing.
NEXT_PUBLIC_SAVED_PROVIDER=local

# --- AI concierge (OpenAI-compatible) ---------------------------------------
# Server-only — NEVER prefix with NEXT_PUBLIC (must not reach the browser).
# Empty key => the assistant uses the built-in local mock (no API calls).
# Restart the dev server after changing these.
#
# AI_PROVIDER auto-selects the base URL (groq | openrouter | openai). You can
# also set AI_BASE_URL explicitly to override. Provider-neutral AI_* names are
# read first; OPENAI_* names also work as a fallback.
#
#   Groq  (FREE key, no credit card — recommended):  https://console.groq.com/keys
#     AI_PROVIDER=groq
#     AI_API_KEY=gsk_your_key_here
#     AI_MODEL=llama-3.3-70b-versatile      # or llama-3.1-8b-instant (faster)
#
#   OpenRouter (has free models):                    https://openrouter.ai/keys
#     AI_PROVIDER=openrouter
#     AI_API_KEY=sk-or-your_key_here
#     AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
#   OpenAI (PAID — needs billing/credits, otherwise HTTP 429):
#     AI_PROVIDER=openai
#     AI_API_KEY=sk-your_key_here
#     AI_MODEL=gpt-4.1-mini
#
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=gpt-4.1-mini
