# --- Saved-properties persistence -------------------------------------------
# Which backend the saved shortlist uses.
#
#   local  (default) Browser localStorage. Works offline, per-browser.
#   api              The /api/saved route.
#
# NOTE: with "api", storage is currently an in-memory mock
# (lib/server/savedStore.ts) — it resets on server restart and is NOT shared
# across serverless instances. Swap that file for PostgreSQL to make it durable.
#
# This is a NEXT_PUBLIC_ var: it's read in the browser and inlined at build time,
# so rebuild after changing it.
NEXT_PUBLIC_SAVED_PROVIDER=local
